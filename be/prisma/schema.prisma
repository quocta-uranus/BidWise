generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum RoleType {
  ADMIN
  MODERATOR
  CLIENT
  FREELANCER
}

enum OtpType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  TWO_FACTOR
}

enum OtpStatus {
  PENDING
  VERIFIED
  EXPIRED
  REVOKED
}

enum SessionStatus {
  ACTIVE
  LOGGED_OUT
  EXPIRED
  REVOKED
}

enum AccountActionType {
  REGISTERED
  EMAIL_VERIFIED
  SUSPENDED
  UNSUSPENDED
  DEACTIVATED
  PASSWORD_CHANGED
  ROLE_ASSIGNED
  ROLE_REVOKED
}

enum JobStatus {
  DRAFT
  OPEN
  CLOSED
  IN_PROGRESS
  COMPLETED
  DISPUTED
}

enum AuctionType {
  SEALED_BID
  OPEN_BID
}

enum BudgetFormat {
  FIXED
  RANGE
}

enum BidStatus {
  PENDING
  SHORTLISTED
  ACCEPTED
  REJECTED
  WITHDRAWN
  EXPIRED
}

enum ContractStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  DISPUTED
  CANCELLED
}

enum MilestoneStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

enum ContractActionType {
  CREATED
  ACTIVATED
  PAUSED
  RESUMED
  COMPLETED
  DISPUTED
  CANCELLED
  MILESTONE_APPROVED
  MILESTONE_REJECTED
}

// ─── CORE TABLES ─────────────────────────────────────────────────────────────

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  passwordHash     String
  fullName         String
  avatarUrl        String?
  bio              String?
  phone            String?
  status           UserStatus @default(PENDING_VERIFICATION)
  emailVerifiedAt  DateTime?
  lastLoginAt      DateTime?
  failedLoginCount Int        @default(0)
  lockedUntil      DateTime?
  twoFactorEnabled Boolean    @default(false)
  twoFactorSecret  String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?

  userRoles           UserRole[]
  otpVerifications    OtpVerification[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  loginSessions       LoginSession[]
  accountLogs         AccountStatusLog[]
  clientJobs          Job[]              @relation("ClientJobs")
  freelancerBids      Bid[]              @relation("FreelancerBids")
  wallet              Wallet?
  freelancerProfile   FreelancerProfile?
  bookmarks           JobBookmark[]
  jobAlerts           JobAlert?
  reviewsGiven        Review[]           @relation("ReviewerRelation")
  reviewsReceived     Review[]           @relation("RevieweeRelation")
  clientContracts     Contract[]         @relation("ClientContracts")
  freelancerContracts Contract[]         @relation("FreelancerContracts")

  @@index([email])
  @@index([status])
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  name        RoleType @unique
  description String?
  createdAt   DateTime @default(now())

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(cuid())
  resource    String
  action      String
  description String?

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model UserRole {
  id         String   @id @default(cuid())
  userId     String
  roleId     String
  assignedBy String?
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ─── OTP & TOKEN TABLES ──────────────────────────────────────────────────────

model OtpVerification {
  id           String    @id @default(cuid())
  userId       String
  type         OtpType
  codeHash     String
  status       OtpStatus @default(PENDING)
  attemptCount Int        @default(0)
  sendCount    Int        @default(0)
  expiresAt    DateTime
  verifiedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, status])
  @@map("otp_verifications")
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  sessionId  String
  isRevoked  Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  revokedAt  DateTime?
  replacedBy String?

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  session LoginSession @relation(fields: [sessionId], references: [id])

  @@index([userId, isRevoked])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  isUsed    Boolean  @default(false)
  expiresAt  DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  ipAddress String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ─── SESSION & AUDIT TABLES ──────────────────────────────────────────────────

model LoginSession {
  id           String        @id @default(cuid())
  userId       String
  status       SessionStatus @default(ACTIVE)
  ipAddress    String
  userAgent    String?
  deviceType   String?
  deviceName   String?
  location     String?
  lastActiveAt DateTime      @default(now())
  loggedOutAt  DateTime?
  createdAt    DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId, status])
  @@map("login_sessions")
}

model AccountStatusLog {
  id          String            @id @default(cuid())
  userId      String
  action      AccountActionType
  reason      String?
  performedBy String?
  metadata    Json?
  createdAt   DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account_status_logs")
}

// ─── JOB MANAGEMENT TABLES ───────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobs Job[]

  @@map("categories")
}

model Job {
  id           String       @id @default(cuid())
  clientId     String
  title        String
  description  String
  budgetFormat BudgetFormat
  minBudget    Float?
  maxBudget    Float?
  fixedBudget  Float?
  budget       Float?
  deadline     DateTime
  categoryId   String
  auctionType  AuctionType  @default(SEALED_BID)
  status       JobStatus    @default(DRAFT)
  sealedOpenedAt DateTime?
  editDeadlineHours Int     @default(24)
  skills       String[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  client       User            @relation("ClientJobs", fields: [clientId], references: [id])
  category     Category        @relation(fields: [categoryId], references: [id])
  ahpWeight    AhpWeight?
  attachments  JobAttachment[]
  bids         Bid[]
  bookmarks    JobBookmark[]
  jobSkills    JobSkill[]
  contracts    Contract[]

  @@index([clientId])
  @@index([categoryId])
  @@index([status])
  @@map("jobs")
}

model JobSkill {
  id        String   @id @default(cuid())
  jobId     String
  name      String
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("job_skills")
}

model AhpWeight {
  id               String   @id @default(cuid())
  jobId            String   @unique
  priceWeight      Float    @default(0)
  skillWeight      Float    @default(0)
  experienceWeight Float    @default(0)
  ratingWeight     Float    @default(0)
  speedWeight      Float    @default(0)
  deadlineWeight   Float    @default(0)
  portfolioWeight  Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("ahp_weights")
}

model JobAttachment {
  id        String   @id @default(cuid())
  jobId     String
  fileName  String
  fileUrl   String
  fileSize  Int?
  mimeType  String?
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("job_attachments")
}

model Bid {
  id           String    @id @default(cuid())
  jobId        String
  freelancerId String
  amount       Float
  deliveryDays Int
  proposal     String
  days         Int?
  coverLetter  String?
  fileName     String?
  fileUrl      String?
  matchingScore Int?
  matchBreakdown Json?
  submittedAt  DateTime  @default(now())
  status       BidStatus @default(PENDING)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  job        Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  freelancer User      @relation("FreelancerBids", fields: [freelancerId], references: [id])
  contract   Contract?

  @@unique([jobId, freelancerId])
  @@index([jobId])
  @@index([freelancerId])
  @@map("bids")
}

// ─── PAYMENTS & ESCROW TABLES ────────────────────────────────────────────────

enum TransactionType {
  EARNED
  WITHDRAW
  ESCROW
  DEPOSIT
  REFUND
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

model Wallet {
  id           String        @id @default(cuid())
  userId       String        @unique
  balance      Float         @default(0)
  escrow       Float         @default(0)
  totalEarned  Float         @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("wallets")
}

model Transaction {
  id          String            @id @default(cuid())
  walletId    String
  type        TransactionType
  amount      Float
  description String
  descKey     String?
  descParams  Json?
  date        DateTime          @default(now())
  status      TransactionStatus @default(PENDING)
  wallet      Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Review {
  id            String   @id @default(cuid())
  contractId    String
  reviewerId    String
  revieweeId    String
  qualityRating Float
  commRating    Float
  speedRating   Float
  comment       String   @default("")
  anonymous     Boolean  @default(false)
  createdAt     DateTime @default(now())

  contract      Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  reviewer      User     @relation("ReviewerRelation", fields: [reviewerId], references: [id])
  reviewee      User     @relation("RevieweeRelation", fields: [revieweeId], references: [id])

  @@map("reviews")
}
// ─── FREELANCER TABLES ───────────────────────────────────────────────────────

model FreelancerProfile {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  hourlyRate             Float?
  experience             String?
  skills                 String[]
  available              Boolean   @default(true)
  bidTokens              Int       @default(10)
  bidTokensUsed          Int       @default(0)
  bidPenalties           Int       @default(0)
  lastBidDate            String?
  assessmentCompleted    Boolean   @default(false)
  assessmentScore        Int?
  assessmentLevel        String?
  assessmentCompletedAt  DateTime?
  cvFileName             String?
  cvFileUrl              String?
  cvFileSize             Int?
  cvUploadedAt           DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolioItems  PortfolioItem[]
  certificates    Certificate[]

  @@index([userId])
  @@map("freelancer_profiles")
}

model PortfolioItem {
  id                    String    @id @default(cuid())
  freelancerProfileId   String
  title                 String
  desc                  String    @default("")
  link                  String    @default("")
  linkType              String?
  fileName              String?
  fileUrl               String?
  fileSize              Int?
  mimeType              String?
  createdAt             DateTime  @default(now())

  profile FreelancerProfile @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)

  @@index([freelancerProfileId])
  @@map("portfolio_items")
}

model Certificate {
  id                    String    @id @default(cuid())
  freelancerProfileId   String
  name                  String
  issuer                String
  date                  String?
  verifyLink            String?
  imageUrl              String?
  imageFileName         String?
  verified              Boolean   @default(false)
  createdAt             DateTime  @default(now())

  profile FreelancerProfile @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)

  @@index([freelancerProfileId])
  @@map("certificates")
}

// ─── BOOKMARK & ALERT TABLES ─────────────────────────────────────────────────

model JobBookmark {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
  @@map("job_bookmarks")
}

model JobAlert {
  id           String   @id @default(cuid())
  userId       String   @unique
  enabled      Boolean  @default(true)
  frequency    String   @default("daily") // "daily" | "instant"
  lastSentAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("job_alerts")
}

// ─── CONTRACT & MILESTONE TABLES ─────────────────────────────────────────────

model Contract {
  id               String         @id @default(cuid())
  jobId            String
  bidId            String         @unique
  clientId         String
  freelancerId     String
  title            String
  description      String?
  totalAmount      Float
  status           ContractStatus @default(DRAFT)
  termsAndConds    String?
  customTerms      String?
  startDate        DateTime?
  endDate          DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  cancelReason     String?
  disputeReason    String?
  autoApprovalDays Int            @default(5)
  clientReviewed     Boolean        @default(false)
  freelancerReviewed Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  job          Job                  @relation(fields: [jobId], references: [id])
  bid          Bid                  @relation(fields: [bidId], references: [id])
  client       User                 @relation("ClientContracts", fields: [clientId], references: [id])
  freelancer   User                 @relation("FreelancerContracts", fields: [freelancerId], references: [id])
  milestones   Milestone[]
  statusLogs   ContractStatusLog[]
  reviews      Review[]

  @@index([clientId])
  @@index([freelancerId])
  @@index([jobId])
  @@index([status])
  @@map("contracts")
}

model Milestone {
  id                String          @id @default(cuid())
  contractId        String
  order             Int
  title             String
  description       String?
  amount            Float
  percentage        Float
  deadline          DateTime
  status            MilestoneStatus @default(NOT_STARTED)
  maxRevisions      Int             @default(3)
  revisionCount     Int             @default(0)
  submittedAt       DateTime?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  autoApproveAt     DateTime?
  clientFeedback    String?
  freelancerNotes   String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  contract      Contract              @relation(fields: [contractId], references: [id], onDelete: Cascade)
  deliverables  MilestoneDeliverable[]

  @@index([contractId])
  @@index([status])
  @@map("milestones")
}

model MilestoneDeliverable {
  id          String   @id @default(cuid())
  milestoneId String
  fileName    String
  fileUrl     String
  fileSize    Int?
  mimeType    String?
  description String?
  uploadedAt  DateTime @default(now())

  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@index([milestoneId])
  @@map("milestone_deliverables")
}

model ContractStatusLog {
  id          String             @id @default(cuid())
  contractId  String
  action      ContractActionType
  fromStatus  ContractStatus?
  toStatus    ContractStatus
  reason      String?
  performedBy String?
  metadata    Json?
  createdAt   DateTime           @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@map("contract_status_logs")
}
